@model IEnumerable<SeronDesign.Models.Toy>

@{
    ViewData["Title"] = "Oyuncaklar";
}

<section class="py-4 py-lg-5">
    <div class="container">
        <div class="d-flex flex-wrap gap-3 justify-content-between align-items-center mb-4">
            <div>
                <h1 class="h2 fw-bold mb-1">Oyuncak Koleksiyonu</h1>
                <p class="text-body-secondary mb-0">Eğitici, koleksiyonluk ve özel tasarım oyuncaklar.</p>
            </div>
            <a asp-action="Create" class="btn btn-brand">Yeni Oyuncak Ekle</a>
        </div>

        @if (!Model.Any()) {
            <div class="alert alert-info rounded-3">Henüz oyuncak yok. İlk kaydı şimdi oluşturabilirsiniz.</div>
        } else {
            <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-4">
            @foreach (var toy in Model) {
                <div class="col">
                    <article class="card h-100">
                        <img src="@Url.Content("~/images/" + (toy.ImageName != null ? Uri.EscapeDataString(toy.ImageName) : "placeholder.png"))" class="card-img-top" alt="@toy.Name" style="height: 220px; object-fit: cover;" />
                        <div class="card-body">
                            <h5 class="card-title">@toy.Name</h5>
                            <p class="card-text text-body-secondary">@toy.Description</p>
                        </div>
                        <div class="card-footer bg-white d-flex justify-content-between align-items-center">
                            <small class="text-body-secondary">@(toy.Category?.Name ?? "Kategori yok")</small>
                            <span class="badge text-bg-light border">@toy.Price.ToString("C")</span>
                        </div>
                    </article>
                </div>
            }
            </div>
        }
    </div>
</section>
