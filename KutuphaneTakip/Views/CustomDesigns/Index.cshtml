@model IEnumerable<SeronDesign.Models.CustomDesign>

@{
    ViewData["Title"] = "Özel Tasarımlar";
}

<section class="py-4 py-lg-5">
    <div class="container">
        <div class="d-flex flex-wrap gap-3 justify-content-between align-items-center mb-4">
            <div>
                <h1 class="h2 fw-bold mb-1">Özel Tasarım Talepleri</h1>
                <p class="text-body-secondary mb-0">Müşterilerden gelen en güncel talepler.</p>
            </div>
            <a asp-action="Create" class="btn btn-brand">Yeni Talep Oluştur</a>
        </div>

        @if (!Model.Any()) {
            <div class="alert alert-info rounded-3">Henüz tasarım talebi bulunmuyor.</div>
        } else {
            <div class="card p-2">
                <ul class="list-group list-group-flush">
                @foreach (var design in Model.OrderByDescending(x => x.CreatedDate)) {
                    <li class="list-group-item py-3">
                        <div class="d-flex flex-wrap justify-content-between gap-2">
                            <div>
                                <h6 class="mb-1">@design.Name</h6>
                                <p class="mb-1 text-body-secondary">@design.Description</p>
                                <span class="badge text-bg-light border">@design.CustomerEmail</span>
                            </div>
                            <small class="text-body-secondary">@design.CreatedDate.ToString("g")</small>
                        </div>
                    </li>
                }
                </ul>
            </div>
        }
    </div>
</section>
