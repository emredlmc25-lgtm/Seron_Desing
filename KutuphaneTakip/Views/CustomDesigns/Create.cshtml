@model SeronDesign.Models.CustomDesign

@{
    ViewData["Title"] = "Özel Tasarım Talebi";
}

<section class="py-4 py-lg-5">
    <div class="container" style="max-width: 760px;">
        <div class="card p-4 p-lg-5">
            <h1 class="h3 fw-bold mb-3">Özel Tasarım Talebi Oluştur</h1>
            <p class="text-body-secondary">İhtiyacınızı kısa ve net şekilde yazarak talep oluşturun.</p>

            <form asp-action="Create" novalidate>
                <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>
                <div class="mb-3">
                    <label asp-for="Name" class="form-label">Proje Adı</label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Description" class="form-label">Açıklama</label>
                    <textarea asp-for="Description" class="form-control" rows="5"></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="CustomerName" class="form-label">Adınız</label>
                        <input asp-for="CustomerName" class="form-control" />
                        <span asp-validation-for="CustomerName" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="CustomerEmail" class="form-label">E-posta</label>
                        <input asp-for="CustomerEmail" class="form-control" />
                        <span asp-validation-for="CustomerEmail" class="text-danger"></span>
                    </div>
                </div>
                <div class="d-flex gap-2 mt-4">
                    <a asp-action="Index" class="btn btn-outline-secondary">İptal</a>
                    <button type="submit" class="btn btn-brand">Talep Gönder</button>
                </div>
            </form>
        </div>
    </div>
</section>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
