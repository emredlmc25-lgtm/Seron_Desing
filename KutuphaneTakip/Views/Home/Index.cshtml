@{
    ViewData["Title"] = "Ana Sayfa";
}

<section class="home-hero py-5 py-lg-6">
    <div class="container">
        <div class="row align-items-center g-4 g-lg-5">
            <div class="col-lg-6">
                <span class="kicker">Yenilikçi Tasarım Atölyesi</span>
                <h1 class="display-4 fw-bold mt-3 mb-3">Markanıza uygun ürünleri fikirden prototipe taşıyoruz.</h1>
                <p class="lead text-body-secondary mb-4">Seron Design; özel oyuncak, promosyon ürünü ve kişiselleştirilmiş tasarımlarda hızlı ve kaliteli üretim süreci sunar.</p>
                <div class="d-flex flex-wrap gap-3">
                    <a href="@Url.Action("Index", "Toys")" class="btn btn-brand btn-lg">Oyuncakları İncele</a>
                    <a href="@Url.Action("Create", "CustomDesigns")" class="btn btn-outline-brand btn-lg">Özel Talep Başlat</a>
                </div>
                <div class="hero-stats mt-4">
                    <div class="stat-item">
                        <strong>150+</strong>
                        <span>Tamamlanan Tasarım</span>
                    </div>
                    <div class="stat-item">
                        <strong>48 saat</strong>
                        <span>Ortalama Dönüş</span>
                    </div>
                    <div class="stat-item">
                        <strong>%95</strong>
                        <span>Müşteri Memnuniyeti</span>
                    </div>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="hero-media">
                    <img src="~/images/SERON_DESING.jpg" alt="Seron Design ürünleri" class="img-fluid rounded-4 shadow-lg" />
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-5">
    <div class="container">
        <div class="section-heading mb-4">
            <h2 class="mb-2">Hizmet Alanları</h2>
            <p class="text-body-secondary mb-0">İhtiyacınıza uygun üretim akışını seçin, geri kalan tüm süreci biz yönetelim.</p>
        </div>

        <div class="row g-4">
            <div class="col-md-4">
                <article class="card service-card h-100">
                    <div class="card-body">
                        <span class="service-badge">Oyuncak</span>
                        <h5 class="card-title mt-3">Eğitici ve Koleksiyonluk Oyuncaklar</h5>
                        <p class="card-text text-body-secondary">Fikirden son ürüne kadar detaylı modelleme ve kaliteli malzeme seçimi.</p>
                        <a href="@Url.Action("Index", "Toys")" class="link-brand">Keşfet</a>
                    </div>
                </article>
            </div>

            <div class="col-md-4">
                <article class="card service-card h-100">
                    <div class="card-body">
                        <span class="service-badge">Ürün</span>
                        <h5 class="card-title mt-3">Günlük Kullanım Ürünleri</h5>
                        <p class="card-text text-body-secondary">İşlevselliği estetikle birleştiren modern ürün tasarımları.</p>
                        <a href="@Url.Action("Index", "Products")" class="link-brand">Keşfet</a>
                    </div>
                </article>
            </div>

            <div class="col-md-4">
                <article class="card service-card h-100">
                    <div class="card-body">
                        <span class="service-badge">Özel</span>
                        <h5 class="card-title mt-3">Kişiselleştirilmiş Tasarımlar</h5>
                        <p class="card-text text-body-secondary">Kurumsal veya bireysel taleplerinize uygun tekil üretim süreci.</p>
                        <a href="@Url.Action("Index", "CustomDesigns")" class="link-brand">Keşfet</a>
                    </div>
                </article>
            </div>
        </div>
    </div>
</section>
